<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkApplicationWindow" id="window">
    <property name="hexpand">True</property>
    <property name="vexpand">True</property>
    <child>
      <object class="GtkGrid">
        <property name="visible">True</property>
        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
        <child>
          <object class="GtkLabel" id="main_label">
            <property name="visible">True</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="hexpand">True</property>
            <property name="vexpand">False</property>
            <property name="label" translatable="yes">Temel Linux Araçları</property>
            <layout>
              <property name="column">0</property>
              <property name="row">0</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="orientation">horizontal</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="hexpand">True</property>
            <property name="vexpand">False</property>
            <property name="spacing">25</property>
            <property name="homogeneous">True</property>
            <child>
              <object class="GtkButton" id="free_ram">
                <property name="label" translatable="yes">Ram Kullanımı</property>
                <property name="visible">True</property>
                <property name="hexpand">True</property>
                <property name="vexpand">False</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="clean_cache">
                <property name="label" translatable="yes">Ram Önbellek Temizleme</property>
                <property name="visible">True</property>
                <property name="hexpand">True</property>
                <property name="vexpand">False</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="kernel_version">
                <property name="label" translatable="yes">Kernel Versiyonu</property>
                <property name="visible">True</property>
                <property name="hexpand">True</property>
                <property name="vexpand">False</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="sistemi_kapat">
                <property name="label" translatable="yes">Sistemi Kapat</property>
                <property name="visible">True</property>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">1</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="orientation">horizontal</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="hexpand">True</property>
            <property name="vexpand">False</property>
            <property name="spacing">77</property>
            <property name="homogeneous">True</property>
            <child>
              <object class="GtkButton" id="reboot">
                <property name="label" translatable="yes">Yeniden Başlat</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="logout">
                <property name="label" translatable="yes">Oturumu Kapat</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="username">
                <property name="label" translatable="yes">Kullanıcı Adım Ne?</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="disc_usage">
                <property name="label" translatable="yes">Disk Kullanımı</property>
                <property name="visible">True</property>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">2</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="orientation">horizontal</property>
            <property name="margin-start">20</property>
            <property name="margin-end">20</property>
            <property name="margin-top">20</property>
            <property name="margin-bottom">20</property>
            <property name="hexpand">True</property>
            <property name="vexpand">False</property>
            <property name="spacing">25</property>
            <property name="homogeneous">True</property>
            <child>
              <object class="GtkButton" id="cpu_info">
                <property name="label" translatable="yes">İşlemci Bilgisi</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="network_info">
                <property name="label" translatable="yes">Ağ Bilgisi</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="uptime">
                <property name="label" translatable="yes">Çalışma Süresi</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="os_info">
                <property name="label" translatable="yes">Dağıtım Bilgisi</property>
                <property name="visible">True</property>
              </object>
            </child>
            <child>
              <object class="GtkButton" id="battery">
                <property name="label" translatable="yes">Pil Durumu</property>
                <property name="visible">True</property>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">3</property>
            </layout>
          </object>
        </child>
        <child>
          <object class="GtkScrolledWindow">
            <property name="visible">True</property>
            <property name="margin-top">20</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="hscrollbar-policy">automatic</property>
            <property name="vscrollbar-policy">automatic</property>
            <property name="has-frame">True</property>
            <child>
              <object class="GtkTextView" id="output_view">
                <property name="visible">True</property>
                <property name="editable">False</property>
                <property name="cursor-visible">False</property>
                <property name="monospace">True</property>
                <property name="left-margin">8</property>
                <property name="right-margin">8</property>
                <property name="top-margin">8</property>
                <property name="bottom-margin">8</property>
              </object>
            </child>
            <layout>
              <property name="column">0</property>
              <property name="row">4</property>
            </layout>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
